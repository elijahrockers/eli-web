---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Clinical data engineer building AI systems for healthcare" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-800 antialiased">
    <nav class="fixed top-0 w-full bg-white/80 backdrop-blur-sm border-b border-slate-200 z-50">
      <div class="max-w-4xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="#" class="font-bold text-slate-900">Elijah Rockers</a>
        <div class="flex gap-6 text-sm text-slate-600">
          <a href="#about" class="hover:text-slate-900 transition-colors">About</a>
          <a href="#projects" class="hover:text-slate-900 transition-colors">Projects</a>
          <a href="#resume" class="hover:text-slate-900 transition-colors">Resume</a>
          <a href="#contact" class="hover:text-slate-900 transition-colors">Contact</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="bg-slate-900 text-slate-400 py-8">
      <div class="max-w-4xl mx-auto px-6 text-center text-sm">
        <p>&copy; {new Date().getFullYear()} Elijah Rockers</p>
      </div>
    </footer>
  </body>
</html>
