---
---

<section id="resume" class="py-20 px-4 sm:px-6 bg-white dark:bg-slate-900">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-8">Resume</h2>

    <div class="space-y-8">
      <div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-2">Skills</h3>
        <div class="flex flex-wrap gap-2">
          {[
            "Python", "R", "SQL", "DICOM", "Epic (Clarity, Caboodle)", "Machine Learning",
            "Computer Vision", "HPC", "Docker/Apptainer", "Linux (RHEL / Rocky)", "Git",
            "Web Application Deployment", "System Administration", "Data Wrangling", "Architecture Review",
          ].map((skill) => (
            <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm rounded-full">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">Experience</h3>
        <div class="space-y-6">
          <div class="border-l-2 border-blue-500 dark:border-blue-400 pl-4">
            <p class="font-medium text-slate-900 dark:text-slate-100">Systems Architect</p>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-2">Houston Methodist — HDSA / DHI &middot; Aug 2025 – Present</p>
            <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1 list-disc list-inside">
              <li>Mentored junior data scientists on geocoding app, LLM data dictionary, and Text-to-SQL projects</li>
              <li>Architecture design/review of second NVIDIA DGX supercomputer with Rice University</li>
              <li>HIPAA compliant business practices for structured, unstructured, and clinical research data</li>
              <li>Spearheaded Git-based repos and wiki documentation across 15+ analysts</li>
              <li>Led Linux infrastructure adoption, sandbox environment, and trained data scientists</li>
              <li>Researched and implemented PACS-to-XNAT bridging solutions</li>
            </ul>
          </div>
          <div class="border-l-2 border-slate-300 dark:border-slate-600 pl-4">
            <p class="font-medium text-slate-900 dark:text-slate-100">Senior Application Analyst</p>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-2">Houston Methodist — Clinical Research Informatics &middot; July 2022 – Aug 2025</p>
            <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1 list-disc list-inside">
              <li>Automated PHI scrubbing, tokenization, and secure inter-institutional data transfers</li>
              <li>Deployed ECG-GPT Docker container for inference on HPC using Apptainer</li>
              <li>Developed and containerized CT-based sarcopenia ML pipeline</li>
              <li>Designed ECG image processing workflows for cardiovascular research</li>
              <li>Resolved critical MRI data transfer issue, coordinating with XNAT and Siemens engineering</li>
            </ul>
          </div>
          <div class="border-l-2 border-slate-300 dark:border-slate-600 pl-4">
            <p class="font-medium text-slate-900 dark:text-slate-100">Application Analyst &rarr; Senior Application Analyst</p>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-2">Houston Methodist — Clinical Research Informatics &middot; Feb 2021 – July 2022</p>
            <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1 list-disc list-inside">
              <li>Scaled REDCap and XNAT to enterprise-wide platforms, 21 CFR Part 11 compliance</li>
              <li>Designed HPC environment and led NVIDIA Bright Cluster Manager migration</li>
            </ul>
          </div>
          <div class="border-l-2 border-slate-300 dark:border-slate-600 pl-4">
            <p class="font-medium text-slate-900 dark:text-slate-100">Research Data Analyst &rarr; Biomedical Engineer</p>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-2">Houston Methodist — Nantz National Alzheimer Center &middot; July 2015 – Feb 2021</p>
            <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1 list-disc list-inside">
              <li>Co-authored publications in high-impact medical journals (neuroimaging)</li>
              <li>Represented Houston Methodist at international conferences (MGH, Yale, Merck)</li>
            </ul>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-2">Education</h3>
        <div class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
          <p><span class="font-medium text-slate-800 dark:text-slate-200">Georgia Institute of Technology</span> — MS Computer Science, Machine Learning, 2025</p>
          <p><span class="font-medium text-slate-800 dark:text-slate-200">Texas A&amp;M University</span> — BS Electrical Engineering, 2015</p>
        </div>
      </div>

      <div>
        <a
          href={`${import.meta.env.BASE_URL}resume.pdf`}
          class="inline-flex items-center px-4 py-2 bg-blue-600 dark:bg-blue-500 text-white text-sm font-medium rounded-lg hover:bg-blue-700 dark:hover:bg-blue-400 transition-colors"
        >
          Download Full Resume (PDF)
        </a>
      </div>
    </div>
  </div>
</section>
